# ---- Backend (FastAPI api.py + RQ worker.py) ----

# Database. SQLite by default (local pilot). For Postgres set e.g.:
# ECOURTS_DB_URL=postgresql+psycopg://user:pass@localhost:5432/ecourts
# (a bare postgres:// URL from a managed provider is auto-normalized.)

# Redis: job queue + live-progress pub/sub.
REDIS_URL=redis://localhost:6379/0

# Auth: shared secret. The Next.js app signs a short-lived HS256 JWT with this;
# FastAPI verifies it. MUST be identical on both sides. Use a long random string.
BACKEND_JWT_SECRET=change-me-to-a-long-random-string

# CORS: allowed frontend origin(s), comma-separated.
FRONTEND_ORIGIN=http://localhost:3000

# Optional CORS regex to also allow dynamic origins (e.g. Vercel preview deploys),
# e.g. ^https://your-app[a-zA-Z0-9-]*\.vercel\.app$
FRONTEND_ORIGIN_REGEX=

# Abuse control: max NEW scrapes a user can trigger per day.
ECOURTS_SCRAPES_PER_DAY=10

# OpenAI narrative (optional). Set ECOURTS_AI_SUMMARY=0 to disable (free/offline).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ECOURTS_AI_SUMMARY=1
