# ---------------------------------------------------------------------------
# VM deployment env for docker-compose.yml. Copy to `.env` on the server and
# fill in real values:   cp .env.deploy.example .env
# Do NOT commit the real .env. Consumed by the api, worker, postgres and caddy
# services. The frontend's env vars live in Vercel, not here (see README/plan).
# ---------------------------------------------------------------------------

# ---- Domain (Caddy TLS) ----
# Subdomain whose GoDaddy A record points at this VM's static IP.
API_DOMAIN=api.yourdomain.com

# ---- Postgres (the `postgres` service creates this DB/user on first boot) ----
POSTGRES_DB=ecourts
POSTGRES_USER=ecourts
POSTGRES_PASSWORD=change-me-strong-password

# ---- Database URL the app uses (host = the compose service name `postgres`) ----
# Keep user/password/db in sync with the three POSTGRES_* values above.
ECOURTS_DB_URL=postgresql+psycopg://ecourts:change-me-strong-password@postgres:5432/ecourts

# ---- Redis (queue + live-progress pub/sub; host = compose service `redis`) ----
REDIS_URL=redis://redis:6379/0

# ---- Auth: shared HS256 secret. MUST be byte-identical to BACKEND_JWT_SECRET
#      set in Vercel. Generate one long random string (e.g. `openssl rand -hex 32`).
BACKEND_JWT_SECRET=change-me-to-a-long-random-string

# ---- CORS: the deployed frontend origin(s), comma-separated (the Vercel URL,
#      and/or your custom app domain). No trailing slash. ----
FRONTEND_ORIGIN=https://your-app.vercel.app

# ---- Optional CORS regex to also allow Vercel preview deployments (production
#      + previews). Match your project's URLs, e.g. for project "your-app":
#      ^https://your-app[a-zA-Z0-9-]*\.vercel\.app$  ----
FRONTEND_ORIGIN_REGEX=

# ---- Abuse control: max NEW scrapes a user can trigger per day ----
ECOURTS_SCRAPES_PER_DAY=10

# ---- OpenAI narrative. Set explicitly here (the sibling-project .env fallback
#      in config.py does not exist on the VM). Set ECOURTS_AI_SUMMARY=0 to disable.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ECOURTS_AI_SUMMARY=1
