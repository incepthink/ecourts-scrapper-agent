# Backend API base URL (FastAPI on Render, or local).
NEXT_PUBLIC_API_URL=http://localhost:8000

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Shared secret used to sign the short-lived JWT the backend verifies.
# MUST equal BACKEND_JWT_SECRET on the FastAPI side.
BACKEND_JWT_SECRET=change-me-to-a-long-random-string
